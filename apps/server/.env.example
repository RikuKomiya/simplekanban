# Environment for the Bun dev server (`bun run dev`). Bun auto-loads .env.
# Copy to .env and adjust as needed.

# better-auth
BETTER_AUTH_SECRET=dev-secret-change-me
BETTER_AUTH_URL=http://localhost:8787

# Dev server port (defaults to 8787).
PORT=8787

# The dev server uses file:../../local.db (repo root) and applies
# packages/db/migrations automatically on boot — no Turso vars needed locally.
